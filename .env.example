# Postgres (Docker)
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=TORQMIND
PG_USER=postgres
PG_PASSWORD=1234
DATABASE_URL=postgresql+asyncpg://postgres:1234@postgres:5432/TORQMIND
APP_ENV=dev
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_CORS_ORIGIN_REGEX=^https?://([a-zA-Z0-9.-]+|\\d{1,3}(?:\\.\\d{1,3}){3})(:3000)?$

# API
API_JWT_SECRET=CHANGE_ME_SUPER_SECRET
API_JWT_ISSUER=torqmind-api
API_ACCESS_TOKEN_MINUTES=60
INGEST_REQUIRE_KEY=False
SEED_PASSWORD=TorqMind@123

# Web
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_API_PORT=8000
# Defina NEXT_PUBLIC_API_URL somente se o frontend precisar chamar uma URL publica fixa
# ex.: http://192.168.0.125:8000 ou http://26.10.20.30:8000
NEXT_PUBLIC_API_URL=
