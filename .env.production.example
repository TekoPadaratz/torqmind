# TorqMind production environment example for docker-compose.prod.yml

# Postgres container
POSTGRES_DB=TORQMIND
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# API runtime
APP_ENV=prod
APP_ROOT_PATH=
API_JWT_SECRET=CHANGE_ME_API_JWT_SECRET
API_JWT_ISSUER=torqmind-api
API_ACCESS_TOKEN_MINUTES=60
INGEST_REQUIRE_KEY=true
ETL_INTERNAL_KEY=
APP_CORS_ORIGINS=http://localhost
APP_CORS_ORIGIN_REGEX=^https?://([a-zA-Z0-9.-]+|\d{1,3}(?:\.\d{1,3}){3})(:\d+)?$

# Seed / auth
SEED_PASSWORD=CHANGE_ME_SEED_PASSWORD

# Web
NEXT_PUBLIC_API_PORT=8000

# Optional integrations
TELEGRAM_BOT_TOKEN=
NOTIFY_MIN_SEVERITY=CRITICAL
OPENAI_API_KEY=
JARVIS_MODEL_FAST=gpt-4.1-mini
JARVIS_MODEL_STRONG=gpt-4.1
JARVIS_AI_TOP_N=10
JARVIS_AI_MAX_OUTPUT_TOKENS=500
JARVIS_AI_TIMEOUT_SECONDS=30
JARVIS_AI_RPM_SLEEP_SECONDS=2
JARVIS_AI_INPUT_COST_PER_1M=0.4
JARVIS_AI_OUTPUT_COST_PER_1M=1.6
