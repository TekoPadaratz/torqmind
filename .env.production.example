# TorqMind production environment example for docker-compose.prod.yml

# Postgres container
POSTGRES_DB=TORQMIND
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_SHM_SIZE=1g
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9

# API runtime
APP_ENV=prod
APP_ROOT_PATH=
API_JWT_SECRET=CHANGE_ME_API_JWT_SECRET
API_JWT_ISSUER=torqmind-api
API_ACCESS_TOKEN_MINUTES=60
INGEST_REQUIRE_KEY=true
INGEST_BATCH_SIZE=5000
ETL_INTERNAL_KEY=
# Leave both blank when web and api share the same public origin behind nginx.
# If a separate frontend origin is needed, set explicit origins instead of localhost wildcards.
APP_CORS_ORIGINS=
APP_CORS_ORIGIN_REGEX=
DB_POOL_MIN_SIZE=4
DB_POOL_MAX_SIZE=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_MAX_IDLE_SECONDS=300
BUSINESS_TIMEZONE=America/Sao_Paulo
BUSINESS_TENANT_TIMEZONES=

# Seed / auth
SEED_PASSWORD=CHANGE_ME_SEED_PASSWORD
PLATFORM_MASTER_EMAIL=CHANGE_ME_PLATFORM_MASTER_EMAIL
PLATFORM_MASTER_PASSWORD=CHANGE_ME_PLATFORM_MASTER_PASSWORD
PLATFORM_MASTER_NAME=TorqMind Platform Master
CHANNEL_BOOTSTRAP_EMAIL=CHANGE_ME_CHANNEL_BOOTSTRAP_EMAIL
CHANNEL_BOOTSTRAP_PASSWORD=CHANGE_ME_CHANNEL_BOOTSTRAP_PASSWORD
CHANNEL_BOOTSTRAP_USER_NAME=TorqMind Channel Admin
CHANNEL_BOOTSTRAP_NAME=Canal TorqMind

# Web
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_BUSINESS_TIMEZONE=America/Sao_Paulo

# Optional integrations
TELEGRAM_BOT_TOKEN=
NOTIFY_MIN_SEVERITY=CRITICAL
OPENAI_API_KEY=
JARVIS_MODEL_FAST=gpt-4.1-mini
JARVIS_MODEL_STRONG=gpt-4.1
JARVIS_AI_TOP_N=10
JARVIS_AI_MAX_OUTPUT_TOKENS=500
JARVIS_AI_TIMEOUT_SECONDS=30
JARVIS_AI_RPM_SLEEP_SECONDS=2
JARVIS_AI_INPUT_COST_PER_1M=0.4
JARVIS_AI_OUTPUT_COST_PER_1M=1.6

# ClickHouse
CLICKHOUSE_HOST=torqmind-clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=torqmind_mart
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
USE_CLICKHOUSE=true
DUAL_READ_MODE=false