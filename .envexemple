# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=TORQMIND
PG_USER=postgres
PG_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/TORQMIND
APP_ENV=dev

# API
API_JWT_SECRET=CHANGE_ME_SUPER_SECRET
API_JWT_ISSUER=torqmind-api
API_ACCESS_TOKEN_MINUTES=60
INGEST_REQUIRE_KEY=False

SEED_PASSWORD=TorqMind@123

# Web
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
